# IBM Quantum Platform API token (https://quantum.cloud.ibm.com).
# Without it, scripts/collect_ibm.py logs a message and exits 0 (cron-safe).
IBM_QUANTUM_TOKEN=

# Optional: IBM Cloud instance CRN. If unset, the service picks a default.
IBM_QUANTUM_INSTANCE=

# Optional overrides (defaults shown).
# CALIBRAQ_DB_PATH=data/calibraq.db
# CALIBRAQ_SNAPSHOT_DIR=data/snapshots
